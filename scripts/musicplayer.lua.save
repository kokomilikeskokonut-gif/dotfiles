local function get_command_output(command)No Media Playing ]" end

    local position = tonumber(get_command_output("playerctl position")) or 0 local duration = 
    tonumber(get_command_output("playerctl metadata mpris:length")) or 0
    
    -- playerctl length is in microseconds, position is in seconds duration = duration / 1000000

    if duration <= 0 then return "[ Live Stream ]" end

    local bar_width = math.floor(width * 0.6)
    local progress = position / duration
    local filled = math.floor(bar_width * progress)
    local empty = bar_width - filled

    local bar = "[" .. string.rep("#", filled) .. string.rep("-", empty) .. "]"
    local time_info = string.format(" %d:%02d / %d:%02d", 
        math.floor(position/60), position%60, 
        math.floor(duration/60), duration%60)
    
    return bar .. time_info
end

